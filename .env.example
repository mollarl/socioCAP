# Database Configuration
DATABASE_URL="postgresql://user:password@host:5432/socioCAP"

# Neon Auth Configuration
NEON_AUTH_BASE_URL="https://your-auth-domain.neon.tech"
NEON_AUTH_COOKIE_SECRET="your-secure-cookie-secret-min-32-chars"

# Google Apps Script Configuration
NEXT_PUBLIC_GAS_WEB_APP_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
NEXT_PUBLIC_GAS_WEB_APP_URL_CAP="https://script.google.com/macros/s/YOUR_CAP_DEPLOYMENT_ID/exec"

# Neon API Configuration (for provisioning scripts)
NEON_API_KEY="your-neon-api-key"
NEON_PROJECT_ID="your-neon-project-id"
NEON_BRANCH_NAME="main"
NEON_AUTH_SEED_USERS='[{"email":"admin@example.com","password":"secure-password","name":"Admin","role":"admin"}]'
